# French Tutor Environment Variables
# Copy this to .env and fill in your values

# Required: OpenAI API key for intelligence layer (GPT-4o)
OPENAI_API_KEY=sk-...

# Required: HuggingFace token for PersonaPlex model access
# Get it at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Optional: Override default settings
# GRADIO_SERVER_PORT=7860
