# Dual-Track History Tutor Environment Variables
# Copy this to .env and fill in your values

# Required: OpenAI API key for Whisper STT and TTS
OPENAI_API_KEY=sk-...

# Required: Anthropic API key for Claude responses
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HuggingFace token for Moshi/PersonaPlex model access
# Get it at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Optional: Override default server port
# PORT=7860
